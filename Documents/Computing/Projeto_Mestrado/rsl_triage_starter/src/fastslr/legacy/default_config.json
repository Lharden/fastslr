{
  "global": {
    "WEIGHTS": {
      "title": 2.0,
      "abstract": 1.0,
      "manual_tags": 1.5
    },
    "PONTUACAO_NIVEIS": {
      "1": 10,
      "2": 8,
      "3": 6,
      "4": 4,
      "5": 2
    },
    "UPLIFT_NO_MANUAL_TAGS": 1.17,
    "THRESHOLD_APROVACAO_ESPECIAL": 40.0,
    "LIMITES_APROVADO": {
      "1": 10,
      "2": 12,
      "3": 18,
      "4": 22,
      "5": null
    },
    "LIMITES_SINALIZADO": {
      "1": 6,
      "2": 6,
      "3": 6,
      "4": 7,
      "5": 12
    },
    "FAIL_FAST_GLOBAL": true,
    "MAX_SCORE_POR_SECAO": 30,
    "MAX_GAP_BETWEEN_TERMS": 2,
    "TOKEN_UNIT_FOR_GAPS": "\\S+",
    "ENABLE_PROXIMITY_DETECTION": true
  },

  "fields": {
    "id": "key",
    "id_output": "ID",
    "title": "title",
    "abstract": "abstract",
    "manual_tags": "manual_tags"
  },  

  "encoding": "utf-8",
  "sep": ";",

  "output": {
    "csv": false,
    "xlsx": true,

    "csv_sep": ";",
    "csv_decimal": ",",
    "csv_float_format": "%.2f",

    "xlsx_engine": "xlsxwriter",
    "xlsx_sheet_name": "resultados"
  }
}