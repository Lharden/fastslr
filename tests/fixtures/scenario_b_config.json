    "LIMITES_SINALIZADO": {"1": 6, "2": 6, "3": 6},
    "WEIGHTS": {"title": 2.0, "abstract": 1.0, "manual_tags": 1.5},
    "BLOCK_ORDER": ["TECH", "APP"]
  },
  "fields": {
    "id": "ID",
    "id_output": "ID",
    "title": "Title",
    "abstract": "Abstract",
    "manual_tags": "Manual_Tags"
  },
  "_domain_blocks": ["TECH", "APP"],
