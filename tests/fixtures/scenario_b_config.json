{
  "global": {
    "DECISION_POLICY": "strict",
    "ENABLE_SPECIAL_APPROVAL_RULE": false,
    "SPECIAL_APPROVAL_THRESHOLD": 40.0,
    "FAIL_FAST_GLOBAL": true,
    "NO_TAGS_UPLIFT": 1.17,
