{
  "type": "object",
  "properties": {
    "architecture": {
      "type": "string",
      "description": "High-level architecture description and design decisions"
    },
    "files_to_create": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {"type": "string"},
          "purpose": {"type": "string"}
        },
        "required": ["path", "purpose"]
      }
    },
    "files_to_modify": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {"type": "string"},
          "changes": {"type": "string"}
        },
        "required": ["path", "changes"]
      }
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "External dependencies required (pip packages)"
    },
    "test_strategy": {
      "type": "string",
      "description": "Testing approach: what to test and how"
    }
  },
  "required": ["architecture", "files_to_create", "test_strategy"]
}
