      "enum": ["pipeline", "ask", "explore", "code", "review", "plan"]
    },
    "codex_model": {
      "type": "string",
      "enum": ["gpt-5.3-codex-spark", "gpt-5.3-codex", "gpt-5.1-codex-max"]
    },
    "review_model": {
      "type": "string",
      "enum": ["haiku", "sonnet", "opus"]
    },
    "thinking_budget": {
      "type": "integer",
      "minimum": 0,
      "maximum": 128000
    },
    "reasoning": {
      "type": "string"
    }
  },
  "required": ["mode", "codex_model", "reasoning"],
  "additionalProperties": false
}
